{
  "name": "gitguard-ui",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "axios": "^1.15.2",
    "concurrently": "^9.2.1",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^5.2.0"
  },
  "scripts": { 
 "start": "set PORT=3001 && react-scripts start",
 "build": "react-scripts build",
